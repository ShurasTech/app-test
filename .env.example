# app-test environment variables
# Copy this file to `.env` on the VPS deploy path (/opt/projects/app-test) and fill in real values.
# NEVER put a real Discord webhook URL in this file or in any committed file —
# the webhook is entered by the end user in the app's own UI and stored only
# in their browser's localStorage (see NFR2 / AD-6 in the architecture spine).

# Domain this app-test's dedicated Traefik should serve.
DOMAIN=app.shuras.tech

# Public IP of the VPS's main network interface (NOT the tailscale0 IP).
# Get it with: curl -4 ifconfig.me
# Explicitly scoping the bind to this IP (rather than 0.0.0.0) prevents any
# collision with homelab-infra's internal Traefik, which is bound only to
# the tailscale interface IP (see homelab-infra services/traefik).
PUBLIC_IP=

# Email used for Let's Encrypt ACME registration (expiry notices only).
ACME_EMAIL=

TZ=America/Sao_Paulo
